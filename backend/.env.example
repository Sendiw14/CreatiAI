PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/creatiai

# JWT — generate strong secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic Claude — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL (for CORS) — Vite dev server default
FRONTEND_URL=http://localhost:5173

# Optional: email (for verification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@creatiai.com

